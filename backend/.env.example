# ============================================================
# PepsiCo Distributor Platform — Backend Environment Variables
# Copy this file to .env and fill in your values.
# ALL of these must also be set in Vercel Dashboard →
#   Project Settings → Environment Variables
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key

# ── Admin Security ────────────────────────────────────────────
# A long random secret — used to protect all /api/admin/* routes
ADMIN_API_KEY=your-very-long-random-secret-key

# ── Razorpay Payments ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Email (Gmail SMTP) ────────────────────────────────────────
# Use a Gmail App Password (not your real Gmail password)
# Enable 2FA → Google Account → Security → App Passwords
Email_User=yourname@gmail.com
Email_Pass=abcd efgh ijkl mnop

# ── Application URLs ──────────────────────────────────────────
# Set FRONTEND_URL to your deployed Vercel URL
FRONTEND_URL=https://your-project.vercel.app

# ── Optional ──────────────────────────────────────────────────
# Port (only used when running locally, Vercel ignores this)
PORT=5001

# Daily email report recipient (defaults to Email_User if not set)
# DAILY_REPORT_EMAIL=admin@yourdomain.com

# Cron timezone (defaults to Asia/Kolkata)
# REPORT_CRON_TIMEZONE=Asia/Kolkata

# ── DO NOT SET IN PRODUCTION ─────────────────────────────────
# This disables TLS certificate verification — local dev only
# NODE_TLS_REJECT_UNAUTHORIZED=0
