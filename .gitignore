# Dependencies
node_modules/
.pnp
.pnp.js

# Environment files (secrets — never commit)
.env
.env.local
.env.*.local
backend/.env
frontend/.env.development

# Allow these safe non-secret env files:
!.env.example
!backend/.env.example
!frontend/.env.production

# Build output
dist/
frontend/dist/
build/

# Vite internal cache
frontend/.vite/


# Uploaded user files
uploads/
reports/

# Logs
logs/
*.log
*.pid
migrate-uploads-apply.log

# macOS
.DS_Store
.AppleDouble
.LSFiles
.Spotlight-V100
.Trashes

# Temporary / scratch files
scratch_*.js
scratch_*.cjs
test_*.js
debug_*.js

# Lock files (keep package-lock, ignore yarn)
yarn.lock

# Supabase local dev
supabase/.temp/

# One-off migration helpers at root (keep only database/ dir)
EXECUTE_THIS_MIGRATION.sql
MIGRATION_CLEAN.sql
RUN_THIS_MIGRATION.sql
